# ─── Backend (place in backend/.env) ─────────────────────────────────────────

# Port the Express API listens on (Cloud Run injects PORT=8080 automatically).
PORT=3001

# Google Cloud project ID. When set, the backend uses Vertex AI (Gemini +
# text-embedding-004). Leave blank to run in the offline local-fallback mode.
GCP_PROJECT_ID=

# Vertex AI region (default us-central1).
GCP_LOCATION=us-central1

# Set to "true" to query traffic data live from BigQuery instead of the bundled
# JSON file. Requires running `node scripts/init_bq.js` first.
USE_BIGQUERY=false

# Set to "true" to persist citizen reports and action memos in Firestore.
# Requires running `node scripts/init_firestore.js` first.
USE_FIRESTORE=false

# Set to "true" to use AlloyDB / PostgreSQL pgvector as the vector store for RAG.
# Requires running `node scripts/init_alloydb.js` first.
USE_ALLOYDB=false
DATABASE_URL=

# Comma-separated list of allowed CORS origins (production only).
CORS_ORIGIN=

# Optional shared secret. If set, all /api requests must send x-api-key.
BACKEND_API_KEY=

# ─── Frontend (place in frontend/.env) ───────────────────────────────────────

# Base URL of the backend API. Leave blank for local dev (Astro proxies /api).
# In production, set to the deployed Cloud Run URL.
PUBLIC_API_URL=
