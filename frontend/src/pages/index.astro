---
import Layout from '../layouts/Layout.astro';
import MapView from '../components/MapView.jsx';
import Dashboard from '../components/Dashboard.jsx';
import QueryBar from '../components/QueryBar.jsx';
---

<Layout>
  <main className="min-h-screen bg-slate-50 p-6">
    <div className="max-w-7xl mx-auto space-y-6">
      <header className="mb-8">
        <h1 className="text-3xl font-bold text-slate-900 tracking-tight">CityPulse Dashboard</h1>
        <p className="text-slate-500 mt-1">Real-time urban mobility intelligence</p>
      </header>

      {/* Query Bar for NLP interaction */}
      <QueryBar client:load />

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Map View */}
        <div className="lg:col-span-1">
          <MapView client:only="react" />
        </div>

        {/* Dashboard Panels */}
        <div className="lg:col-span-2">
          <Dashboard client:load />
        </div>
      </div>
    </div>
  </main>
</Layout>
