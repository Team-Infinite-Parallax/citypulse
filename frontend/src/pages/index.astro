---
import Layout from '../layouts/Layout.astro';
import MapView from '../components/MapView.jsx';
import Dashboard from '../components/Dashboard.jsx';
import QueryBar from '../components/QueryBar.jsx';
import AlertsPanel from '../components/AlertsPanel.jsx';
import RecommendationCard from '../components/RecommendationCard.jsx';
---

<Layout>
  <div class="p-4 sm:p-6 lg:p-8">
    <div class="max-w-[1600px] mx-auto space-y-8 lg:space-y-10">

      <!-- Query Bar -->
      <QueryBar client:load />

      <!-- Map: Hero section - full width, dominant -->
      <section aria-label="Traffic Map" class="relative">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-1 h-5 rounded-full bg-[#31D0AA] shadow-[0_0_8px_rgba(49,208,170,0.6)]"></span>
          <h2 class="text-lg font-bold" style="color: var(--amber)">Traffic Map</h2>
          <span class="eyebrow ml-auto hidden sm:block">Bengaluru · Live Network</span>
        </div>
        <div class="relative">
          <MapView client:only="react" />
          <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#0B0E14] to-transparent rounded-b-[16px]"></div>
        </div>
      </section>

      <!-- Live Telemetry -->
      <section aria-label="Live Telemetry">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-1 h-5 rounded-full bg-[#31D0AA] shadow-[0_0_8px_rgba(49,208,170,0.6)]"></span>
          <h2 class="text-lg font-bold" style="color: var(--amber)">Live Telemetry</h2>
        </div>
        <Dashboard client:load />
      </section>

      <!-- Alerts + AI Recommendations -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
        <AlertsPanel client:load />
        <RecommendationCard client:load />
      </div>

    </div>
  </div>
</Layout>
